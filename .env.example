# Copy to .env. Both fields are optional but recommended.

# Contact address for the ACME (Let's Encrypt) account. Used for cert-expiry
# warnings and account recovery. Set this to a real inbox you check.
CADDY_EMAIL=

# ACME endpoint. Defaults to Let's Encrypt production. Flip to staging during
# initial setup to avoid burning prod rate limits while iterating:
#   ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA=https://acme-v02.api.letsencrypt.org/directory
